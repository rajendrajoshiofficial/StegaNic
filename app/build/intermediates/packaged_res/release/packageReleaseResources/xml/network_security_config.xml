<?xml version="1.0" encoding="utf-8"?>
<!--
    StegaNic Network Security Configuration
    Blocks ALL cleartext (HTTP) and encrypted (HTTPS) network traffic.
    This app is designed to be 100% offline — no connections, ever.
-->
<network-security-config>
    <!-- Block all cleartext traffic -->
    <base-config cleartextTrafficPermitted="false">
        <!-- No trusted anchors = no HTTPS connections possible -->
        <trust-anchors/>
    </base-config>
</network-security-config>
